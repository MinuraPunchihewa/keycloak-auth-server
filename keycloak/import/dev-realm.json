{
  "realm": "dev",
  "enabled": true,
  "displayName": "Keycloak Auth Server",
  "displayNameHtml": "Keycloak Auth Server",
  "loginTheme": "app-theme",
  "registrationAllowed": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "roles": {
    "realm": [
      {
        "name": "buyer",
        "description": "Buyer persona"
      },
      {
        "name": "seller",
        "description": "Seller persona"
      }
    ]
  },
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@localhost",
    "fromDisplayName": "Dev Realm",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "YOUR_GOOGLE_CLIENT_ID",
        "clientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
        "useJwksUrl": "true",
        "defaultScope": "openid profile email"
      }
    }
  ],
  "clients": [
    {
      "clientId": "fastapi-server",
      "name": "FastAPI Server",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:8000",
      "baseUrl": "http://localhost:8000",
      "redirectUris": [
        "http://localhost:8000/*"
      ],
      "webOrigins": [
        "http://localhost:8000"
      ]
    },
    {
      "clientId": "fastapi-admin",
      "name": "FastAPI Admin Service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-admin-secret-change-me",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "service-account-fastapi-admin",
      "enabled": true,
      "serviceAccountClientId": "fastapi-admin",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users"
        ]
      }
    }
  ]
}
