{
  "realm": "dev",
  "enabled": true,
  "displayName": "Dev Realm",
  "registrationAllowed": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@localhost",
    "fromDisplayName": "Dev Realm",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "YOUR_GOOGLE_CLIENT_ID",
        "clientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
        "useJwksUrl": "true",
        "defaultScope": "openid profile email"
      }
    }
  ],
  "clients": [
    {
      "clientId": "fastapi-server",
      "name": "FastAPI Server",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:8000",
      "baseUrl": "http://localhost:8000",
      "redirectUris": [
        "http://localhost:8000/*"
      ],
      "webOrigins": [
        "http://localhost:8000"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Demo",
      "email": "alice@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ]
    }
  ]
